<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <Button
        android:id="@+id/btnPickVideo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Pick Video"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txtSelected"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="No video selected"
        android:paddingTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnPickVideo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
        android:id="@+id/edtUserId"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="UserId (UUID)"
        android:inputType="text"
        android:paddingTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/txtSelected"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
        android:id="@+id/edtDuration"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="DurationSeconds (e.g. 10)"
        android:inputType="number"
        android:paddingTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/edtUserId"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnUpload"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Upload"
        android:enabled="false"
        android:paddingTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/edtDuration"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txtResult"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:paddingTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnUpload"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>